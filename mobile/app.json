{
  "expo": {
    "name": "CFC Wallet",
    "slug": "cfc-wallet",
    "version": "3.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A8A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.me.cfcwallet.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.jpeg",
        "backgroundColor": "#1E3A8A"
      },
      "package": "com.cfcwallet.app"
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "cfcwallet",
    "extra": {
      "apiUrl": "https://cfcwallet.vercel.app/api/v1",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "be905f06-cb6e-47bd-a982-156c144a0c48"
      }
    }
  }
}
