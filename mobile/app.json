{
  "expo": {
    "name": "CFC Wallet",
    "slug": "cfc-wallet",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/splash-icon.jpeg",
      "resizeMode": "contain",
      "backgroundColor": "#1E3A8A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.me.cfcwallet.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.jpeg",
        "backgroundColor": "#1E3A8A"
      },
      "package": "com.me.cfcwallet.v2"
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "cfcwallet",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "0624ff0e-ad55-40ae-a9a2-4568de08ae92"
      }
    }
  }
}
