# ─── Security ───────────────────────────────────────────────
CRYPTOJSPW=
JWT_SECRET=
TOKENDATE=14d

# ─── Mail ────────────────────────────────────────────────────
MAILHOST=
MAILEMAIL=
MAILPASSWORD=

# ─── SageCloud Payment Gateway ───────────────────────────────
PUBLIC_KEY=
SECRET_KEY=
TEST_MODE=false

# ─── Database ────────────────────────────────────────────────
DB_DIALECT=mysql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=

# ─── Server ──────────────────────────────────────────────────
# NOTE: Do not set PORT on Vercel — it is managed automatically
PORT=4000
API_PREFIX=/api/v1

# ─── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100000

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:4000,https://yourdomain.com

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
